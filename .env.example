# ============================================================
# PLACELY BACKEND — ENVIRONMENT VARIABLES
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Get this from MongoDB Atlas: Cluster > Connect > Drivers > copy the string.
# Replace <password> with your DB user's password and add the db name.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/placely?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/placely

# --- Auth (JWT) ---
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- CORS ---
# Your frontend URL(s), comma-separated. In production, set your Vercel URL.
CORS_ORIGINS=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
